meta {
  name: Logout
  type: http
  seq: 10
}

post {
  url: {{base_url}}/api/v1/auth/logout
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

script:post-response {
  if (res.getStatus() === 204) {
    bru.setVar("access_token", "");
    bru.setVar("refresh_token", "");
  }
}

tests {
  test("status is 204 No Content", function() {
    expect(res.getStatus()).to.equal(204);
  });
}