meta {
  name: Register - Invalid Email (expect 422)
  type: http
  seq: 4
}

post {
  url: {{base_url}}/api/v1/auth/register
  body: json
  auth: none
}

body:json {
  {
    "email": "not-an-email",
    "srp_verifier": "",
    "srp_salt": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=",
    "argon2_salt": "BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB",
    "ed25519_public_key": "CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC",
    "x25519_public_key": "DDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDD",
    "encrypted_private_key": "EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE"
  }
}

tests {
  test("status is 422", function() {
    expect(res.getStatus()).to.equal(422);
  });

  test("error code is VALIDATION_ERROR", function() {
    expect(res.getBody().code).to.equal("VALIDATION_ERROR");
  });
}