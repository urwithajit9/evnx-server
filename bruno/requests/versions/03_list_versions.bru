meta {
  name: List All Versions
  type: http
  seq: 3
}

get {
  url: {{base_url}}/api/v1/vaults/{{vault_id}}/versions
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("versions array in response", function() {
    expect(res.getBody()).to.have.property("versions");
  });
}