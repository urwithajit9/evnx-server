meta {
  name: Push Version (cloud push)
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/v1/vaults/{{vault_id}}/versions
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "nonce": "AAAAAAAAAAAAAAAAAAAAAAAA",
    "ciphertext": "BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB",
    "blob_hash": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
    "key_names": ["DATABASE_URL", "API_KEY", "DEBUG"],
    "key_count": 3,
    "base_version": 0
  }
}

script:post-response {
  if (res.getStatus() === 201) {
    bru.setVar("version_num", res.getBody().version_num);
  }
}

tests {
  test("status is 201", function() {
    expect(res.getStatus()).to.equal(201);
  });

  test("version_num in response", function() {
    expect(res.getBody()).to.have.property("version_num");
  });
}