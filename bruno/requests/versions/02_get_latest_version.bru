meta {
  name: Get Latest Version
  type: http
  seq: 2
}

get {
  url: {{base_url}}/api/v1/vaults/{{vault_id}}/versions/latest
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("version_num in response", function() {
    expect(res.getBody()).to.have.property("version_num");
  });
}