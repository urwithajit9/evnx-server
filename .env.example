# # .env.example — updated for Hetzner deployment

# # ─── Storage ───────────────────────────────────────────────────────────────────
# # Hetzner Object Storage:
# #   Region: fsn1 (Falkenstein), nbg1 (Nuremberg), hel1 (Helsinki)
# #   Endpoint: https://{region}.your-objectstorage.com
# #   IMPORTANT: DO NOT set force_path_style — Hetzner uses virtual-hosted style
# #   Bucket naming: lowercase letters, numbers, hyphens only (3-63 chars)
# S3_BUCKET=evnx-vaults-prod
# S3_REGION=fsn1
# S3_ENDPOINT=https://fsn1.your-objectstorage.com
# AWS_ACCESS_KEY_ID=your_hetzner_access_key
# AWS_SECRET_ACCESS_KEY=your_hetzner_secret_key

# # LocalStack (local dev only — comment out for production):
# # S3_BUCKET=evnx-vaults-dev
# # S3_REGION=us-east-1
# # S3_ENDPOINT=http://localhost:4566
# # AWS_ACCESS_KEY_ID=test
# # AWS_SECRET_ACCESS_KEY=test